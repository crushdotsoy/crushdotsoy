  <div class="absolute -bottom-20 -right-20 w-96 h-96 bg-[#A9A5E8]/30 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto text-center">
    <div data-reveal="up" class="mb-6 inline-flex items-center gap-2 bg-[#FDD4E0] text-[#2D2640] px-4 py-2 rounded-full text-sm font-semibold shadow-sm">
      ✨ Open source, always
    </div>

    <h1 data-reveal="up" style="--reveal-delay: 80ms;" class="font-heading text-5xl sm:text-7xl font-black text-[#2D2640] leading-tight mb-6">
      Free.<br />Open.<br />
      <span class="text-[#F4A0B5]">Bright.</span>

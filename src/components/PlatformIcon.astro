---
import type { Platform } from '../types/platform';

interface Props {
  platform: Platform;
  class?: string;
}

const { platform, class: className = '' } = Astro.props;
---

{platform === 'macOS' && (
  <svg
    viewBox="0 0 24 24"
    class={className}
    aria-hidden="true"
    focusable="false"
  >
    <circle cx="12" cy="12" r="12" fill="#FEFCFF" />
    <path
      fill="#111111"
      d="M15.228 11.694c.018 1.934 1.698 2.578 1.717 2.586-.014.046-.269.927-.889 1.839-.536.789-1.092 1.576-1.969 1.592-.861.016-1.138-.511-2.123-.511-.985 0-1.293.495-2.107.527-.846.032-1.49-.847-2.03-1.633C6.716 14.479 5.87 11.53 7.011 9.55c.567-.983 1.58-1.605 2.679-1.621.835-.016 1.623.559 2.123.559.5 0 1.437-.691 2.422-.589.412.017 1.568.166 2.309 1.252-.06.037-1.378.805-1.316 2.543Zm-1.57-5.229c.449-.544.752-1.301.669-2.053-.647.026-1.43.43-1.894.974-.416.48-.78 1.252-.682 1.989.721.056 1.458-.366 1.907-.91Z"
    />
  </svg>
)}

{platform === 'Windows' && (
  <svg
    viewBox="0 0 24 24"
    class={className}
    aria-hidden="true"
    focusable="false"
  >
    <g transform="translate(4 4)">
      <rect x="0" y="0" width="7" height="7" rx="0.7" fill="#0078D4" />
      <rect x="9" y="0" width="7" height="7" rx="0.7" fill="#0078D4" />
      <rect x="0" y="9" width="7" height="7" rx="0.7" fill="#0078D4" />
      <rect x="9" y="9" width="7" height="7" rx="0.7" fill="#0078D4" />
    </g>
  </svg>
)}

{platform === 'Linux' && (
  <svg
    viewBox="0 0 24 24"
    class={className}
    aria-hidden="true"
    focusable="false"
  >
    <ellipse cx="12" cy="9" rx="3.85" ry="4.35" fill="#2F3742" />
    <ellipse cx="12" cy="14.7" rx="5.55" ry="5.95" fill="#2F3742" />
    <ellipse cx="12" cy="15.35" rx="3.75" ry="4.85" fill="#FEFCFF" />
    <path fill="#2F3742" d="M7.85 12.55c-1.05.95-1.7 2.47-1.7 4.17 0 .57.08 1.12.23 1.64-1.22-.1-2.14-.68-2.73-1.3.31-1.88 1.55-3.68 4.2-4.51Zm8.3 0c2.65.83 3.89 2.63 4.2 4.51-.59.62-1.51 1.2-2.73 1.3.15-.52.23-1.07.23-1.64 0-1.7-.65-3.22-1.7-4.17Z" />
    <circle cx="10.55" cy="9.8" r="0.68" fill="#111111" />
    <circle cx="13.45" cy="9.8" r="0.68" fill="#111111" />
    <path fill="#F59E0B" d="M12 10.95 10.72 12.05h2.56L12 10.95Z" />
    <path fill="#F59E0B" d="M8.2 20.05c0 1.02-1.22 1.85-2.73 1.85-1.18 0-2.1-.49-2.47-1.17.94-.52 2.58-1.29 4.32-2.46.56.39.88.98.88 1.78Zm7.6 0c0 1.02 1.22 1.85 2.73 1.85 1.18 0 2.1-.49 2.47-1.17-.94-.52-2.58-1.29-4.32-2.46-.56.39-.88.98-.88 1.78Z" />
  </svg>
)}
